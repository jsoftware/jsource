%.o: %.cpp
	$(CXX) -c $(CPPFLAGS) -o$@ $^

%.o: %.c
	$(CC) -c -o $@ $< $(CFLAGS) $(CFLAGS_SIMD) $(CFLAGS_FMA) $(CFLAGS_AESNI) $(CFLAGS_AESARM) $(CFLAGS_BASE64)

%.o: %.S
	$(CC) $(GASM_FLAGS) -c -o $@ $<

%.o: %.asm
	$(NASM) $(NASM_FLAGS) -o $@ $<

$(OBJS_FMA) : CFLAGS_FMA := -mfma
$(OBJS_AESNI) : CFLAGS_AESNI := -maes
$(OBJS_AESARM) : CFLAGS_AESARM := -march=armv8-a+crc+crypto
$(OBJS_BASE64) : CFLAGS_BASE64 := $(FLAGS_BASE64)
ifneq (windows,$(findstring windows,$(jplatform)))
$(ODIR)/$(TARGET) : $(OBJS) $(OBJS_BASE64) $(OBJS_FMA) $(OBJS_AESNI) $(OBJS_AESARM) $(OBJS_SIMDUTF8) $(SRC_ASM) $(OBJSLN) $(BACKTRACE_OBJS)
	$(CC) -o $@ $(OBJS) $(OBJS_BASE64) $(OBJS_FMA) $(OBJS_AESNI) $(OBJS_AESARM) $(OBJS_SIMDUTF8) $(OBJS_ASM) $(SRC_ASM) $(LDFLAGS) $(OBJSLN) $(BACKTRACE_OBJS)
else
$(ODIR)/$(TARGET) : $(OBJS) $(OBJS_BASE64) $(OBJS_FMA) $(OBJS_AESNI) $(OBJS_AESARM) $(OBJS_SIMDUTF8) $(SRC_ASM) $(DLLOBJS) $(LIBJDEF) $(LIBJRES) $(OBJSLN) $(BACKTRACE_OBJS)
	$(CXX) -o $@ $(OBJS) $(OBJS_BASE64) $(OBJS_FMA) $(OBJS_AESNI) $(OBJS_AESARM) $(OBJS_SIMDUTF8) $(OBJS_ASM) $(SRC_ASM) $(DLLOBJS) $(LIBJDEF) $(LIBJRES) $(LDFLAGS) $(OBJSLN) $(BACKTRACE_OBJS)
endif

%.res: %.rc
	$(WINDRES) -l 0x409 -D _USING_V110_SDK71_ -r -O COFF -o $@ $^

all: $(ODIR)/$(TARGET)

clean:
	rm -f $(OBJS) $(OBJS_BASE64) $(OBJS_FMA) $(OBJS_AESNI) $(OBJS_AESARM) $(OBJS_SIMDUTF8) $(SRC_ASM) $(DLLOBJS) $(LIBJRES) $(OBJSLN) $(BACKTRACE_OBJS)

.PHONY: all clean
