vpath % ../../../../jsrc % ../../../../libbacktrace

ODIR=../../../../bin/$(jplatform64)

.SUFFIXES: .o

OBJS=  \
 jconsole.o \
 jeload.o \
 $(BACKTRACE_OBJS)

%.o: %.c
	$(CC) -c -o $@ $< $(CFLAGS)

$(ODIR)/$(TARGET) : $(OBJS) $(OBJSLN)
	$(CC) -o $@ $(OBJS) $(OBJSLN) -g $(LDFLAGS)

all: $(ODIR)/$(TARGET)

clean:
	rm -f $(OBJS) $(OBJSLN) linenoise.o

.PHONY: all clean
